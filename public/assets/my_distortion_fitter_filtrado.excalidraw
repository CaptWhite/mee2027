      "version": 578,
      "versionNonce": 644882525,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "zTf6W4sk3T22wt37jX9Xc",
          "type": "arrow"
        },
        {
          "id": "ECgztTz0zAPvpT1tCUwG1",
