      "y": 1418.286411511938,
      "width": 561.818592608421,
      "height": 130.9444383887749,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "HWQEOudh-vjgV3cFGMdBR"
      ],
      "frameId": null,
      "index": "b1k",
      "roundness": null,
      "seed": 1606027200,
      "version": 1535,
      "versionNonce": 16466845,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "dK_5Y8rCD3GSkJWTyHSMF",
          "type": "arrow"
        }
      ],
      "updated": 1782115147896,
      "link": null,
      "locked": false,
      "text": "Se transforman las coordenadas de las estrellas observadas utilizando la\nestimación final de la distorsión y se calculan los errores de posición en\npíxeles comparando las coordenadas corregidas con las coordenadas\noriginales.\nSe calcula la correlación de error entre cada estrella y su vecino más cercano,\nutilizando las coordenadas de las estrellas observadas y los errores de\nposición en píxeles. ",
      "fontSize": 14.965078673002843,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Se transforman las coordenadas de las estrellas observadas utilizando la estimación final de la distorsión y se calculan los errores de posición en píxeles comparando las coordenadas corregidas con las coordenadas originales.\nSe calcula la correlación de error entre cada estrella y su vecino más cercano, utilizando las coordenadas de las estrellas observadas y los errores de posición en píxeles. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
